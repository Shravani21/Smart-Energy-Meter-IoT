/******************** LIBRARIES ********************/
#include <ArduinoIoTCloud.h>
#include <Arduino_ConnectionHandler.h>
#include <WiFi.h>
#include "EmonLib.h"
#include <LiquidCrystal.h>

/******************** LCD ********************/
LiquidCrystal lcd(2, 15, 19, 18, 5, 4);

/******************** ENERGY MONITOR ********************/
EnergyMonitor emon;

/******************** CLOUD VARIABLES ********************/
CloudFloat current;
CloudFloat volt;
CloudInt unit;
CloudInt cost;
CloudBool due;

/******************** LOCAL VARIABLES ********************/
float power = 0.0;
float kWh = 0.0;
unsigned long lastMillis = 0;
int counter = 0;

/******************** IOT CLOUD CREDENTIALS ********************/
const char DEVICE_LOGIN_NAME[] = "ecce5588-293c-405f-8063-29b548fea9c7";
const char SSID[] = "projectiot";
const char PASS[] = "123456789";
const char DEVICE_KEY[] = "w2uSUCD@l9RoARozNhU92uiwM";

/******************** BUTTONS ********************/
#define KEY0 25   // Increment
#define KEY1 26   // Decrement

/******************** CALIBRATION ********************/
#define V_CALIBRATION 136.19
#define I_CALIBRATION 30.0

/******************** FUNCTION DECLARATIONS ********************/
void onCurrentChange();
void onVoltChange();
void onCostChange();
void onUnitChange();
void onDueChange();

void readEnergy();
void updateDisplay();
void updateFromCounter();
int calculateCost(int units);
bool checkDueStatus(int units);
void checkButtons();

/******************** CLOUD INIT ********************/
void initProperties() {
  ArduinoCloud.setBoardId(DEVICE_LOGIN_NAME);
  ArduinoCloud.setSecretDeviceKey(DEVICE_KEY);

  ArduinoCloud.addProperty(current, READWRITE, ON_CHANGE, onCurrentChange);
  ArduinoCloud.addProperty(volt, READWRITE, ON_CHANGE, onVoltChange);
  ArduinoCloud.addProperty(unit, READWRITE, ON_CHANGE, onUnitChange);
  ArduinoCloud.addProperty(cost, READWRITE, ON_CHANGE, onCostChange);
  ArduinoCloud.addProperty(due, READWRITE, ON_CHANGE, onDueChange);
}

WiFiConnectionHandler ArduinoIoTPreferredConnection(SSID, PASS);

/******************** SETUP ********************/
void setup() {
  Serial.begin(115200);
  lcd.begin(16, 2);

  pinMode(KEY0, INPUT_PULLUP);
  pinMode(KEY1, INPUT_PULLUP);
  pinMode(22, OUTPUT);
  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);
  analogSetPinAttenuation(35, ADC_11db);
  analogSetPinAttenuation(34, ADC_11db);
  
  emon.voltage(35, V_CALIBRATION, 1.7);
  emon.current(34, I_CALIBRATION);

  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);

  WiFi.setSleep(false);   

  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  lcd.setCursor(0, 0);
  lcd.print(" Smart Energy ");
  lcd.setCursor(0, 1);
  lcd.print(" Meter - IoT ");
  delay(2000);
  lcd.clear();

  updateFromCounter();
}

/******************** LOOP ********************/
void loop() {
  ArduinoCloud.update();   // MUST run continuously

  unsigned long now = millis();
  if (now - lastMillis >= 1000) {
    readEnergy();
    updateDisplay();
    lastMillis = now;
  }

  checkButtons();
}

/******************** BUTTON HANDLING ********************/
void checkButtons() {
  if (digitalRead(KEY0) == LOW) {
    counter++;
    updateFromCounter();
    delay(250);
  }

  if (digitalRead(KEY1) == LOW) {
    if (counter > 0) counter--;
    updateFromCounter();
    delay(250);
  }
}

/******************** UPDATE UNIT / COST ********************/
void updateFromCounter() {
  unit = counter * 50;
  cost = calculateCost(unit);
  due = checkDueStatus(unit);
}

/******************** ENERGY MEASUREMENT ********************/
void readEnergy() {
  emon.calcVI(20, 2000);   // NO Wi-Fi disconnect here

  volt = emon.Vrms;
  current = emon.Irms;

  if (volt < 50 || volt > 260) volt = 0;
  if (current < 0.15) current = 0;

  power = volt * current;
  kWh += (power / 1000.0) / 3600.0;

  Serial.print("[ENERGY] V=");
  Serial.print(volt, 1);
  Serial.print(" I=");
  Serial.print(current, 3);
  Serial.print(" P=");
  Serial.print(power, 1);
  Serial.println(" W");
}

/******************** COST CALCULATION ********************/
int calculateCost(int units) {
  if (units <= 100) return units * 1.2;
  if (units <= 200) return (100 * 1.2) + (units - 100) * 1.5;
  if (units <= 300) return (100 * 1.2) + (100 * 1.5) + (units - 200) * 1.8;
  return (100 * 1.2) + (100 * 1.5) + (100 * 1.8) + (units - 300) * 2.0;
}

/******************** DUE CHECK ********************/
bool checkDueStatus(int units) {
  return (units > 500);
}

/******************** LCD DISPLAY ********************/
void updateDisplay() {
  lcd.setCursor(0, 0);
  lcd.print("V:");
  lcd.print(volt, 1);
  lcd.print(" I:");
  lcd.print(current, 1);
  lcd.print("   ");

  lcd.setCursor(0, 1);
  lcd.print("U:");
  lcd.print(unit);
  lcd.print(" Rs:");
  lcd.print(cost);
  lcd.print(" ");

  if (due) {
    lcd.setCursor(14, 1);
    lcd.print("DA");
    digitalWrite(22,HIGH);
  } else {
    lcd.setCursor(14, 1);
    lcd.print("  ");
    digitalWrite(22,LOW);
  }
}

/******************** CLOUD CALLBACKS ********************/
void onCurrentChange() {}
void onVoltChange() {}
void onUnitChange() {}
void onCostChange() {}
void onDueChange() {}
